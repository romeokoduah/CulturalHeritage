# Copy this file to `.env` and fill in your own keys.
# The app runs fine without them — AI falls back to the offline guide,
# and voice falls back to the built-in browser voice.

# Kimi AI (Moonshot) — real-time heritage storytelling with up-to-date knowledge
# Get a key at https://platform.moonshot.cn/
VITE_KIMI_API_KEY=

# Deepgram Text-to-Speech (https://console.deepgram.com/)
VITE_DEEPGRAM_API_KEY=

# Optional: the AI Storyteller can also use Claude. That key is entered in the
# in-app Settings screen (stored in your browser), not here.
